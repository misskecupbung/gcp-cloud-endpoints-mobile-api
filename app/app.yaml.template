runtime: python312
instance_class: F1

entrypoint: gunicorn -b :$PORT main:app

env_variables:
  GAE_ENV: "standard"

automatic_scaling:
  min_instances: 0
  max_instances: 2
  target_cpu_utilization: 0.65
  target_throughput_utilization: 0.65

handlers:
  - url: /.*
    script: auto
    secure: always
